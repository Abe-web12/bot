# ============================================================
# FOREX TRADING BOT — ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit .env to version control.
# NEVER share .env contents in chat, logs, or with any AI.
# ============================================================

# ---- MT5 ----
MT5_LOGIN=436568542
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial9
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe

# ---- Telegram ----
# Get token from @BotFather on Telegram.
# Get chat_id from @userinfobot on Telegram.
# IMPORTANT: Rotate these immediately if they were ever shared in plaintext.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_SECRET=
DASHBOARD_PASSWORD=

# ---- Webhook Secret ----
# Used to validate incoming webhook requests from Make.com or TradingView.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# ---- AI / Gemini ----
# Optional. If blank, AI features are disabled at runtime.
# The bot still trades using the rule-based strategy engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Database ----
# SQLite path (relative to project root).
# For PostgreSQL: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///database/forex_bot.db
