# ============================================================
# FOREX TRADING BOT — ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit .env to version control.
# NEVER share .env contents in chat, logs, or with any AI.
# ============================================================
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# ---- MT5 ----
# Set your real MT5 account number. Never commit real credentials.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial9
MT5_PATH=C:/Program Files/MetaTrader 5/terminal64.exe

# ---- Telegram ----
# Get token from @BotFather on Telegram.
# Get chat_id from @userinfobot on Telegram.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Security ----
SECRET_KEY=
JWT_SECRET=
# REQUIRED: Set a strong password (min 16 chars). Never use admin123.
DASHBOARD_PASSWORD=
VIEWER_PASSWORD=

# ---- Webhook Secret ----
WEBHOOK_SECRET=

# ---- AI / Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Database ----
# SQLite: sqlite:///database/forex_bot.db
# PostgreSQL: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///database/forex_bot.db

# ---- Multi-User Auth (SaaS) ----
# Separate JWT secret for user tokens. Falls back to JWT_SECRET if empty.
USER_JWT_SECRET=
BCRYPT_ROUNDS=12

# ---- Email / SMTP ----
# Email features gracefully degrade if SMTP is not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=noreply@forexbot.local

# ---- Site / Branding ----
SITE_NAME=ForexBot
SITE_URL=http://localhost:3000
SUPPORT_EMAIL=support@forexbot.local

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG_MODE=false
LOG_LEVEL=INFO

# ---- Bot ----
USER_JWT_ACCESS_TOKEN_TTL_SECONDS=900
USER_JWT_REFRESH_TOKEN_TTL_SECONDS=604800
