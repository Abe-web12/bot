# =============================================================================
# ForexBot — Production Environment Variables Template
# =============================================================================
# Copy this file to the server as /opt/forexbot/.env
# Fill in ALL values before starting the bot in production.
# Run: python deploy/env/validate_env.py to verify.
# =============================================================================

# ---- MT5 Account ----
MT5_LOGIN=436568542
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial9
MT5_PATH=

# ---- Telegram Notifications ----
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Security (generate each with: python -c "import secrets; print(secrets.token_hex(32))") ----
SECRET_KEY=
JWT_SECRET=
DASHBOARD_PASSWORD=
VIEWER_PASSWORD=
WEBHOOK_SECRET=

# ---- User Auth (SaaS) ----
USER_JWT_SECRET=
BCRYPT_ROUNDS=12

# ---- Email / SMTP ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=noreply@forexbot.local

# ---- AI / Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Database ----
DATABASE_URL=sqlite:///database/forex_bot.db

# ---- Site Configuration ----
SITE_NAME=ForexBot
SITE_URL=https://bot.example.com
SUPPORT_EMAIL=support@example.com

# ---- Server (Docker uses 0.0.0.0) ----
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG_MODE=false
LOG_LEVEL=INFO
